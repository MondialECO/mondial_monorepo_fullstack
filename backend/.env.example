# Copy to .env on the VPS and fill in. NEVER commit the real .env.
# ASP.NET Core maps "__" to config section nesting (Section__Key).

# --- Deployment ---
APP_DOMAIN=api.your-domain.com
ACME_EMAIL=ops@your-domain.com
APP_IMAGE=ghcr.io/mondialeco/backend:latest

# --- Redis (container; password also referenced by the app below) ---
REDIS_PASSWORD=change-me-strong

# --- App configuration (rotated secrets) ---
MongoDbSettings__ConnectionString=mongodb+srv://USER:PASS@cluster0.nsfffx4.mongodb.net/
MongoDbSettings__DatabaseName=MondialEcoDev
JwtSettings__Key=replace-with-256-bit-random-base64
JwtSettings__Issuer=mondialbusiness.eu
JwtSettings__Audience=mondialbusiness.eu
EmailSettings__SmtpServer=smtp.zoho.com
EmailSettings__Port=587
EmailSettings__Email=info@mondialbusiness.eu
EmailSettings__Password=replace-with-smtp-password
Twilio__Enabled=false
Twilio__AccountSid=
Twilio__AuthToken=
Twilio__FromNumber=
Redis__Configuration=redis:6379,password=change-me-strong,abortConnect=False
Redis__InstanceName=Mondial
Cors__AllowedOrigins__0=https://your-frontend-domain
# Optional: OpenTelemetry collector
# OpenTelemetry__OtlpEndpoint=http://otel-collector:4317
